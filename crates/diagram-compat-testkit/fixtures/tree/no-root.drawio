<mxfile>
  <diagram>
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1"/>
        <!-- No root: all vertices have incoming edges (forms a loop with no entry) -->
        <!-- This is actually detected as a cycle first, so we need a different structure -->
        <!-- A -> B -> C -> B (C has parent B, but B also has parent A, and A has parent C creates cycle) -->
        <!-- Let's try: A->B, B->C, C->B - this is a cycle and will be detected as such -->
        <!-- Actually, for true "no root", we need all vertices to have incoming edges but no cycle -->
        <!-- That means we need at least 3 vertices where everyone has a parent -->
        <mxCell id="2" vertex="1">
          <mxGeometry x="0" y="0" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="3" vertex="1">
          <mxGeometry x="0" y="0" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="4" vertex="1">
          <mxGeometry x="0" y="0" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="5" edge="1" source="2" target="3"/>
        <mxCell id="6" edge="1" source="3" target="4"/>
        <mxCell id="7" edge="1" source="4" target="2"/>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
