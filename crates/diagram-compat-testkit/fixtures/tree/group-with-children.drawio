<mxfile>
  <diagram>
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1"/>
        <!-- Single root with 3 children forming a valid tree -->
        <mxCell id="2" vertex="1">
          <mxGeometry x="100" y="0" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="3" vertex="1">
          <mxGeometry x="10" y="10" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="4" vertex="1">
          <mxGeometry x="80" y="10" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="5" vertex="1">
          <mxGeometry x="10" y="60" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="6" edge="1" source="2" target="3"/>
        <mxCell id="7" edge="1" source="2" target="4"/>
        <mxCell id="8" edge="1" source="2" target="5"/>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
