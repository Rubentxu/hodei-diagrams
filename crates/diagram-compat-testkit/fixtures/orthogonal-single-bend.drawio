<mxfile>
  <diagram name="Page-1">
    <mxGraphModel>
      <root>
        <mxCell id="A" value="A" vertex="1">
          <mxGeometry x="50" y="100" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="B" value="B" vertex="1">
          <mxGeometry x="200" y="300" width="50" height="50" as="geometry"/>
        </mxCell>
        <!-- Single-bend L-shape: east(100,125) → bend → west(200,325) -->
        <mxCell id="e1" edge="1" source="A" target="B">
          <mxGeometry>
            <Array as="points">
              <mxPoint x="100" y="125"/>
              <mxPoint x="200" y="125"/>
              <mxPoint x="200" y="325"/>
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
