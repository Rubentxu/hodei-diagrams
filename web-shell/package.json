{
  "name": "hodei-diagrams-web-shell",
  "version": "0.1.0",
  "description": "TypeScript web shell for the Hodei Diagrams engine — viewer v1 + editor v1.1",
  "type": "module",
  "private": true,
  "peerWasmVersion": "0.5.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:wasm": "cd .. && wasm-pack build --target web crates/diagram-wasm --out-dir web-shell/src/wasm",
    "preview": "vite preview",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build:wasm && npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^9.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "idb": "^8.0.3"
  }
}
