<mxfile>
  <diagram>
    <mxGraphModel>
      <root>
        <!-- Two shapes that partially overlap in the center -->
        <!-- Shape A: left half -->
        <mxCell id="2" vertex="1" value="ShapeA">
          <mxGeometry x="80" y="80" width="100" height="80" as="geometry"/>
        </mxCell>
        <!-- Shape B: right half, overlapping Shape A by 40px in center -->
        <mxCell id="3" vertex="1" value="ShapeB">
          <mxGeometry x="140" y="80" width="100" height="80" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
