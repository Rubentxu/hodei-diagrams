<shapes name="flowchart">
  <shape name="Process" w="80" h="40" aspect="variable">
    <background>
      <path>M 0,0 L 80,0 L 80,40 L 0,40 Z</path>
    </background>
    <foreground>
      <fill/>
    </foreground>
  </shape>
  <shape name="Decision" w="60" h="60" aspect="fixed">
    <background>
      <path>M 30,0 L 60,30 L 30,60 L 0,30 Z</path>
    </background>
    <foreground>
      <stroke/>
    </foreground>
  </shape>
  <shape name="Terminator" w="100" h="30" aspect="variable">
    <background>
      <path>M 10,0 L 90,0 C 95,0 100,5 100,15 C 100,25 95,30 90,30 L 10,30 C 5,30 0,25 0,15 C 0,5 5,0 10,0 Z</path>
    </background>
    <foreground>
      <fillstroke/>
      <strokewidth/>
    </foreground>
  </shape>
</shapes>
