<mxfile>
  <diagram>
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Shape inside initial viewport: at (20, 20) size 100x60 -->
        <mxCell id="2" vertex="1">
          <mxGeometry x="20" y="20" width="100" height="60" as="geometry"/>
        </mxCell>
        <!-- Shape far outside initial viewport: at (2000, 2000) size 50x50 -->
        <mxCell id="3" vertex="1">
          <mxGeometry x="2000" y="2000" width="50" height="50" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
