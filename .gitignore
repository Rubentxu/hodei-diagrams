# Build artifacts
target/
**/target/

# Rust
# Cargo.lock IS committed — do NOT add it here
.cargo/
*.pdb                    # Windows debug symbols

# WASM builds (trunk)
web-shell/dist/
web-shell/.parcel-cache/

# Node / Web artifacts
node_modules/
dist/
.cache/
.parcel-cache/

# JS/TS logs
npm-debug.log*
yarn-debug.log*
yarn-error.log
pnpm-debug.log*

# Environment — NEVER commit secrets
.env
.env.*
.env*.local

# Test reports
playwright-report/
playwright/.cache/
test-results/
coverage/
*.lcov

# Bundler / framework caches
.turbo/
.next/
.nuxt/
.vite/
.rollup.cache/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Local Engram caches
.atl/

# Local docs — not published until public
docs/

# sccache (dev-only, not for release)
# (sccache data lives in ~/.cache/sccache by default — keep that way)
sddk/

# Playwright visual evidence — screenshots, videos, traces, diff images
# (directories already ignored above; patterns catch stray file extensions)
*.trace.zip
*.webm
*.snap.png
__snapshots__/
playwright/.cache/

# Debug examples — temporary debugging scripts left in crates/**/examples/
# during feature work (should not be committed; remove when no longer needed)
crates/**/examples/
